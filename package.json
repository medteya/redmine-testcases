{
  "name": "redmine_testcases",
  "version": "1.0.0",
  "description": "Automated test suite validating core navigation and search features in Redmine.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:headless": "playwright test --headed=false",
