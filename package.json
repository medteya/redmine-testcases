  },
  "keywords": [
    "playwright",
    "testing",
    "redmine",
    "automation"
  ],
  "author": "Daria Yurchenko",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0"
  }
}
